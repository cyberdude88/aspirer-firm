# Copy to .env.local and fill in real values. Never commit .env.local.

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Google OAuth (Sign-In) ---
# Console: https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000/api/auth/callback/google as authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Calendar (owner / business account) ---
# This is the Gmail account whose calendar is bookable.
GOOGLE_CALENDAR_OWNER_EMAIL=
GOOGLE_CALENDAR_ID=primary
# Refresh token for the owner account, obtained once via offline OAuth flow.
# Scope must include https://www.googleapis.com/auth/calendar.events
GOOGLE_OWNER_REFRESH_TOKEN=

# --- Supabase ---
# Project URL + anon key from https://app.supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key for server-side writes (NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional: hard-coded price IDs per service slug
STRIPE_PRICE_STRESS_MANAGEMENT=
STRIPE_PRICE_LIFE_COACHING=
STRIPE_PRICE_COUNSELING=
STRIPE_PRICE_BUSINESS_COACHING=
STRIPE_PRICE_INTERPERSONAL=
STRIPE_PRICE_ASSERTIVE=
STRIPE_PRICE_INTRO=
