# Copy to .env.local and fill in real values. Never commit .env.local.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Google OAuth / Calendar ---
# Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Calendar (owner / coaching account) ---
GOOGLE_CALENDAR_OWNER_EMAIL=owner@example.com
GOOGLE_CALENDAR_ID=primary
# Refresh token for the owner account, obtained once via offline OAuth flow.
# Scope must include https://www.googleapis.com/auth/calendar.events
GOOGLE_OWNER_REFRESH_TOKEN=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
# Either public key name works; keep one populated.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin (booking queue) ---
# Admin login uses Supabase Auth email/password.
# Grant admin access in Supabase Auth app_metadata instead of app env vars:
# - role: "admin" or is_admin: true
# IANA timezone used to generate 9am–5pm weekday slots.
BUSINESS_TZ=Europe/Berlin

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs per paid service slug
STRIPE_PRICE_DIAGNOSTIC=
STRIPE_PRICE_NINETY_DAY_RESET=
STRIPE_PRICE_ANNUAL_PARTNERSHIP=
STRIPE_PRICE_TEAM_WORKSHOPS=
