# Copy to .env.local and fill in real values. Never commit .env.local.

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Google OAuth (Sign-In) ---
# Console: https://console.cloud.google.com/apis/credentials
# Add both:
# - http://localhost:3000/api/auth/callback/google
# - https://aspirerfirm.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Calendar (owner / coaching account) ---
GOOGLE_CALENDAR_OWNER_EMAIL=marie.cook@aspirerfirm.com
GOOGLE_CALENDAR_ID=primary
# Refresh token for the owner account, obtained once via offline OAuth flow.
# Scope must include https://www.googleapis.com/auth/calendar.events
GOOGLE_OWNER_REFRESH_TOKEN=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
# Either public key name works; keep one populated.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin (booking queue) ---
# Admin login uses Supabase Auth email/password. Keep the admin user password
# in Supabase Auth, not in app env vars. These emails are the server-side
# allowlist for reaching /admin/bookings after authentication.
ADMIN_EMAIL=marie.cook@aspirerfirm.com
SECONDARY_ADMIN_EMAIL=
# IANA timezone used to generate 9am–5pm weekday slots.
BUSINESS_TZ=Europe/Berlin

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs per service slug
STRIPE_PRICE_MINDSET_SESSION=
STRIPE_PRICE_CONFLICT_COMMUNICATION=
STRIPE_PRICE_SELF_DOUBT=
STRIPE_PRICE_RESILIENCE=
